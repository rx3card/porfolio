---
const fetchRows = [
  { key: "Host", value: "Oscar Rojas" },
  { key: "OS", value: "Linux + Windows" },
  { key: "WM", value: "dwm — build propio" },
  { key: "Shell", value: "bash / powershell" },
  { key: "Lenguajes", value: "C, Python, TypeScript, JS" },
  { key: "Stack web", value: "React, Next.js, Astro" },
  { key: "Formación", value: "Tecnólogo ADSO — SENA" },
  { key: "Ubicación", value: "Ibagué, Tolima — CO" },
  { key: "Contacto", value: "rx3card@gmail.com" },
];
---

<section id="sobre-mi" aria-label="Sobre mí">
  <div class="section-head reveal">
    <span class="label">[02] — Sobre mí</span>
    <span class="count">$ cfetch</span>
  </div>

  <div class="about-grid">
    <div class="about-text reveal">
      <p class="big">Me gusta entender cómo funcionan las cosas por detrás.</p>
      <p>
        Disfruto moverme entre distintas tecnologías según lo que requiera cada proyecto, ya sea desarrollando aplicaciones web, automatizando tareas o explorando herramientas más cercanas al sistema. Intento mantener un enfoque práctico: priorizar soluciones claras, cuidar los detalles y pensar en quienes van a utilizar el software. Valoro la curiosidad, la capacidad de adaptación y el aprendizaje continuo. Siempre hay algo nuevo por descubrir, mejorar o replantear, y esa es precisamente una de las cosas que más disfruto de este oficio.
      </p>
      <p>
       Durante los últimos meses he desarrollado y mantenido una plataforma utilizada diariamente por una empresa real. El proyecto incluye un CRM, un bot de WhatsApp integrado con la API de Meta, un asistente BI conversacional capaz de analizar información del negocio mediante lenguaje natural y generar respuestas basadas en datos reales del sistema, chat en tiempo real, informes contables y procesos automatizados orientados a mejorar la operación y la experiencia de los usuarios.
      </p>
      <p>
        Soy Tecnólogo en Análisis y Desarrollo de Software (SENA) y autodidacta desde hace años. Disfruto aprender constantemente, asumir nuevos retos y seguir construyendo soluciones que generen un impacto real.
      </p>
    </div>

    <div
      class="fetch-card reveal"
      role="img"
      aria-label="Tarjeta de información estilo neofetch sobre Oscar Rojas"
    >
      <div class="fetch-titlebar">
        <span class="dot red"></span>
        <span class="dot yellow"></span>
        <span class="dot green"></span>
        <span class="fetch-title">rx3card@gmail.com: ~</span>
      </div>
      <div class="fetch-body">
        <p class="fetch-cmd"><span class="fetch-prompt">$</span> cfetch</p>
        <div class="fetch-output">
          <img
            src="/profile.jpg"
            alt="Foto de Oscar Rojas"
            class="fetch-photo"
            width="300"
            height="300"
            loading="lazy"
          />
          <div class="fetch-info">
            <p class="fetch-user">rx3card<span class="at">@</span>gmail.com</p>
            <p class="fetch-sep">─────────────────</p>
            {
              fetchRows.map((row) => (
                <p class="fetch-row">
                  <span class="fetch-key">{row.key}</span>: {row.value}
                </p>
              ))
            }
          </div>
        </div>
        <div class="fetch-palette" aria-hidden="true">
          {Array.from({ length: 8 }).map(() => <span class="swatch" />)}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
  }

  .about-text {
    display: grid;
    gap: 1.4rem;
    font-weight: 300;
    font-size: 1.05rem;
    color: var(--muted);
    max-width: 36rem;
  }

  .about-text .big {
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    font-weight: 400;
    line-height: 1.3;
    color: var(--ink);
    text-wrap: balance;
  }

  /* ---- cfetch terminal card ----
     una terminal es oscura siempre, también en modo claro */
  .fetch-card {
    --bg: #0a0a09;
    --bg-raise: #111110;
    --ink: #edede8;
    --muted: #8b8b84;
    --line: rgba(237, 237, 232, 0.12);
    --accent: #c6f432;
    border: 1px solid var(--line);
    background: var(--bg-raise);
    color: var(--ink);
    box-shadow: 8px 8px 0 0 color-mix(in srgb, var(--accent) 22%, transparent);
  }

  .fetch-titlebar {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.7rem 1rem;
    border-bottom: 1px solid var(--line);
  }

  .dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    opacity: 0.85;
  }

  .dot.red {
    background: #ff5f57;
  }
  .dot.yellow {
    background: #febc2e;
  }
  .dot.green {
    background: #28c840;
  }

  .fetch-title {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--muted);
    margin-left: 0.5rem;
  }

  .fetch-body {
    padding: 1.4rem 1.5rem 1.6rem;
    font-family: var(--font-mono);
    font-size: clamp(0.72rem, 1.3vw, 0.82rem);
    line-height: 1.85;
  }

  .fetch-output {
    display: flex;
    gap: 1.4rem;
    align-items: flex-start;
  }

  .fetch-photo {
    width: clamp(92px, 11vw, 132px);
    height: auto;
    aspect-ratio: 1;
    object-fit: cover;
    filter: grayscale(1) contrast(1.08);
    border: 1px solid var(--line);
    margin-top: 0.4rem;
    transition: filter 0.4s ease;
  }

  .fetch-card:hover .fetch-photo {
    filter: none;
  }

  .fetch-info {
    min-width: 0;
  }

  .fetch-row {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .fetch-cmd {
    color: var(--muted);
    margin-bottom: 0.8rem;
  }

  .fetch-prompt {
    color: var(--accent);
  }

  .fetch-user {
    color: var(--accent);
    font-weight: 700;
  }

  .fetch-user .at {
    color: var(--ink);
    font-weight: 400;
  }

  .fetch-sep {
    color: var(--muted);
    opacity: 0.6;
  }

  .fetch-key {
    color: var(--accent);
    font-weight: 500;
  }

  .fetch-palette {
    display: flex;
    gap: 0;
    margin-top: 1.1rem;
  }

  .swatch {
    width: 1.6em;
    height: 1em;
  }

  .swatch:nth-child(1) {
    background: #1c1c1b;
  }
  .swatch:nth-child(2) {
    background: #ff5f57;
  }
  .swatch:nth-child(3) {
    background: #c6f432;
  }
  .swatch:nth-child(4) {
    background: #febc2e;
  }
  .swatch:nth-child(5) {
    background: #57a8ff;
  }
  .swatch:nth-child(6) {
    background: #c792ea;
  }
  .swatch:nth-child(7) {
    background: #6fe3d4;
  }
  .swatch:nth-child(8) {
    background: #edede8;
  }

  @media (max-width: 860px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 460px) {
    .fetch-output {
      flex-direction: column;
    }
    .fetch-photo {
      width: 120px;
    }
  }
</style>
